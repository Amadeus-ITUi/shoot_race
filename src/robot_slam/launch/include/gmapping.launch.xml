<launch>
  <arg name="scan_topic"  default="scan" />
  <arg name="base_frame"  default="base_link"/>
  <arg name="odom_frame"  default="odom"/>

  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <!-- 坐标帧 -->
    <param name="base_frame" value="$(arg base_frame)"/>
    <param name="odom_frame" value="$(arg odom_frame)"/>

    <!-- 地图更新频率 (越小更新越快，但CPU负荷大) -->
    <param name="map_update_interval" value="0.05"/> 

    <!-- 激光雷达最大有效测距 -->
    <param name="maxUrange" value="6.0"/>  <!-- 用于扫描匹配 -->
    <param name="maxRange" value="8.0"/>   <!-- 过滤掉超过此距离的点 -->

    <!-- 激光测距噪声，影响 scan matching -->
    <param name="sigma" value="0.05"/>  

    <!-- scan matching 高斯核大小 -->
    <param name="kernelSize" value="1"/> 

    <!-- 搜索步长，越小精度越高但计算量大 -->
    <param name="lstep" value="0.05"/>  
    <param name="astep" value="0.05"/> 

    <!-- 每个 scan 的迭代次数 -->
    <param name="iterations" value="7"/>  

    <!-- 激光特征匹配平滑参数 -->
    <param name="lsigma" value="0.075"/>  

    <!-- 扫描匹配权重 -->
    <param name="ogain" value="3.0"/>  

    <!-- 跳过多少个激光点进行匹配 -->
    <param name="lskip" value="0"/>  

    <!-- 匹配分数阈值 -->
    <param name="minimumScore" value="50"/>  

    <!-- 里程计误差模型: srr/str: 线性， srt/stt: 角度 -->
    <param name="srr" value="0.02"/>  <!-- 线性对线性误差 -->
    <param name="srt" value="0.02"/>  <!-- 线性对角度误差 -->
    <param name="str" value="0.01"/>  <!-- 角度对线性误差 -->
    <param name="stt" value="0.01"/>  <!-- 角度对角度误差 -->

    <!-- 机器人移动多少距离/角度才更新一次地图 -->
    <param name="linearUpdate" value="0.05"/>  
    <param name="angularUpdate" value="0.05"/>  

    <!-- 临时更新间隔，-1表示禁用 -->
    <param name="temporalUpdate" value="-1.0"/>  

    <!-- 重采样阈值 -->
    <param name="resampleThreshold" value="0.5"/>  

    <!-- 粒子数量，越多精度越高，但CPU消耗大 -->
    <param name="particles" value="20"/>  

    <!-- 地图初始范围 -->
    <param name="xmin" value="-10.0"/>
    <param name="ymin" value="-10.0"/>
    <param name="xmax" value="10.0"/>
    <param name="ymax" value="10.0"/>

    <!-- 地图分辨率 (米/像素) -->
    <param name="delta" value="0.02"/>  

    <!-- 粒子采样范围，影响地图收敛速度 -->
    <param name="llsamplerange" value="0.02"/>
    <param name="llsamplestep" value="0.01"/>
    <param name="lasamplerange" value="0.02"/>
    <param name="lasamplestep" value="0.01"/>

    <remap from="scan" to="$(arg scan_topic)"/>
  </node>
</launch>